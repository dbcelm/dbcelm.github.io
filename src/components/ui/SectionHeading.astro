---
interface Props {
  label: string;
  title: string;
  id?: string;
}

const { label, title, id } = Astro.props;
---

<div class="section-heading" id={id}>
  <span class="section-label">{label}</span>
  <h2 class="section-title">{title}</h2>

<style>
  .section-heading {
    margin-bottom: var(--space-lg);
  }
</style>
