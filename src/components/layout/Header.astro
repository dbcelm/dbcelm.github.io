---
import cv from '../../content/cv.json';
---

<header class="header" id="site-header">
  <div class="container header__inner">
    <a href="#" class="header__logo">
      <span class="header__logo-name">{cv.profile.name.split(' ')[0]}</span>
      <span class="header__logo-dot">.</span>
    </a>
    <nav class="header__nav" aria-label="Main navigation">
      {cv.nav.map((item) => (
        <a href={`#${item.id}`} class="header__link" data-nav={item.id}>
          {item.label}
        </a>
      ))}
    </nav>
    <a href={`mailto:${cv.contact.email}`} class="header__cta">Get in touch</a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    background: rgba(10, 10, 11, 0.7);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition), background var(--transition);
  }

  .header.is-scrolled {
    border-bottom-color: var(--color-border);
    background: rgba(10, 10, 11, 0.92);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .header__logo {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    display: flex;
    align-items: baseline;
  }

  .header__logo-dot {
    color: var(--color-accent);
  }

  .header__nav {
    display: none;
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .header__nav {
      display: flex;
    }
  }

  .header__link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
    position: relative;
  }

  .header__link:hover,
  .header__link.is-active {
    color: var(--color-text);
  }

  .header__link.is-active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  .header__cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: border-color var(--transition), background var(--transition);
  }

  .header__cta:hover {
    border-color: var(--color-accent);
    background: var(--color-bg-card);
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const links = document.querySelectorAll('[data-nav]');
  const sections = Array.from(links).map((link) =>
    document.getElementById(link.getAttribute('data-nav') ?? '')
  );

  const onScroll = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 50);

    const scrollPos = window.scrollY + (header?.offsetHeight ?? 0) + 100;
    let activeId = sections[0]?.id ?? '';

    for (const section of sections) {
      if (section && section.offsetTop <= scrollPos) {
        activeId = section.id;
      }
    }

    links.forEach((link) => {
      link.classList.toggle('is-active', link.getAttribute('data-nav') === activeId);
    });
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
